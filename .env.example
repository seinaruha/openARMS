# ============================================
# openARMS Environment Configuration
# 
# Copy this file to .env and update values for your environment
# XAMPP defaults are provided below
# ============================================

# Application Environment (development|production)
OPENARMS_ENV=development

# Database Configuration (XAMPP Defaults)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=openARMS_db

# Application URL (XAMPP default: http://localhost)
APP_URL=http://localhost

# Security (generate random strings for production)
# APP_SECRET=your-random-secret-key-here

# Session Configuration
# SESSION_LIFETIME=3600
